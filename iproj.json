{
  "description": "TallerGitHub - conciliacion contable para IBM i y sistemas abiertos",
  "version": "0.0.1",
  "license": "MIT",
  "repository": "https://github.com/clanuzau/TallerGitHub.git",
  "objlib": "LANUZACX2",
  "curlib": "LANUZACX2",
  "preUsrlibl": [
    "LANUZACX2",
    "QGPL",
    "QTEMP",
    "GAMES400"
  ],
  "postUsrlibl": [],
  "includePath": [
    "Databases",
    "Documentacion_IBMi/Codigo_Ejemplos"
  ],
  "setIBMiEnvCmd": [
    "CHGJOB CCSID(37)"
  ],
  "buildSystem": "tobi",
  "buildSystemVersion": "3.3.0",
  "buildCommand": "makei all",
  "sourceFileExtensions": [
    "sqlrpgle",
    "rpgle",
    "cle",
    "sql",
    "dspf",
    "prtf"
  ],
  "compileOptions": {
    "sqlrpgle": "OPTIMIZE(*FULL) DATFMT(*ISO) TIMFMT(*ISO) TOSRC(*YES) DBGVIEW(*SOURCE)",
    "rpgle": "OPTIMIZE(*FULL) DATFMT(*ISO) TIMFMT(*ISO) DBGVIEW(*SOURCE)",
    "clle": "OPTION(*EVENTF) DBGVIEW(*SOURCE)"
  },
  "binderDirectory": "NOVABND",
  "activationGroup": "NOVA",
  "author": "Cesar Lanuza",
  "team": "Novacomp"
}