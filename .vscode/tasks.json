      "type": "shell",
      "command": "Start-Process -FilePath 'C:\\Users\\Public\\IBM\\ClientSolutions\\Start_Programs\\Windows_x86-64\\acslaunch_win-64.exe' -ArgumentList @('/PLUGIN=rss', '/SYSTEM=pub400.com', '/DATABASE=PUB400', '/FILE=${file}')",
